PORT=3001
JWT_SECRET=replace-with-a-long-random-secret
PUBLIC_API_BASE_URL=http://localhost:3001
CORS_ORIGIN=http://localhost:3000
AUTH_COOKIE_SECURE=false
AUTH_COOKIE_SAME_SITE=lax
# AUTH_COOKIE_DOMAIN=.example.com
API_WORKER_COUNT=4
OPERATIONS_UPLOAD_PATH=./data/uploads/issues

# DA gateway authentication mode
# Credentials are validated against Active Directory and require membership
# in the Omari allow list before creating/updating the application profile.
EXTERNAL_AUTH_LOGIN_URL=http://180.10.1.222:3002/authenticate/login
OMARI_ALLOWLIST_URL_TEMPLATE=http://172.16.3.21:3003/get/users/{username}
EXTERNAL_AUTH_TIMEOUT_MS=8000
EXTERNAL_AUTH_EMAIL_DOMAIN=ad.omari.local

# MySQL runtime
# Verified with MySQL 8.0. The current sync driver expects an application user
# configured with mysql_native_password.
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=omari_inventory
MYSQL_USER=omari_app
MYSQL_PASSWORD=replace-with-a-secure-password
# Keep this false for normal runtime and verification. `npm run db:bootstrap`
# enables explicit database/schema creation via ALLOW_RUNTIME_SCHEMA_MUTATIONS.
MYSQL_AUTO_CREATE_DATABASE=false

# Prisma schema reference
PRISMA_DATABASE_URL=mysql://omari_app:replace-with-a-secure-password@127.0.0.1:3306/omari_inventory
